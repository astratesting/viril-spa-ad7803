// Supabase (Auth). When unset/placeholder, the app falls back to built-in
// credential auth (JWT + JSON store) so the demo works with no backend.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (PostgreSQL). When unset/placeholder, a local JSON file store is used.
DATABASE_URL=

# Auth session
AUTH_SECRET=change-me-in-production

# Stripe (test mode). When unset, payment is simulated in-app.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
